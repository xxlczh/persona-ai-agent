# 数据库配置
DB_HOST=mysql
DB_PORT=3306
DB_USER=root
DB_PASSWORD=password
DB_NAME=persona_ai

# Redis 配置
REDIS_HOST=redis
REDIS_PORT=6379

# JWT 配置
JWT_SECRET=your-secret-key-change-in-production
JWT_EXPIRES_IN=7d

# LLM 配置
OPENAI_API_KEY=
ERNIE_API_KEY=
ZHIPU_API_KEY=
LLM_PROVIDER=openai

# 服务配置
NODE_ENV=production
PORT=3000

# 文件上传配置
UPLOAD_MAX_SIZE=10485760
UPLOAD_ALLOWED_TYPES=txt,json,csv,xlsx,doc,docx,pdf
